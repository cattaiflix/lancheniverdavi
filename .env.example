# Copie este arquivo para .env e preencha com os valores do seu projeto Firebase
VITE_FB_API_KEY=AIza...
VITE_FB_AUTH_DOMAIN=seu-projeto.firebaseapp.com
VITE_FB_DATABASE_URL=https://seu-projeto-default-rtdb.firebaseio.com
VITE_FB_PROJECT_ID=seu-projeto
VITE_FB_STORAGE_BUCKET=seu-projeto.appspot.com
VITE_FB_MESSAGING_SENDER_ID=123456789
VITE_FB_APP_ID=1:123456789:web:abc123
